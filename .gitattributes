# Normalize line endings: store text files with LF in the repo,
# regardless of the contributor's OS. This silences CRLF/LF warnings on Windows.
* text=auto eol=lf

# Binary files: never modify line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.svg text
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.mp4 binary
*.webm binary
